<%#
  Shrimpo card partial — renders a single shrimpo in a list.
  Equivalent to app/components/shrimpo/card.hbs in the Ember frontend.
%>

<%= link_to shrimpo_path(shrimpo.slug),
    class: "m-4 classic:bg-df-pink blm:bg-black rounded-lg border-4 border-white flex justify-between w-full p-2 shadow-md" do %>
  <div>
    <div>
      <% if shrimpo.cover_art_url.present? %>
        <img style="height: 6rem;" src="<%= shrimpo.cover_art_url %>" alt="" />
      <% else %>
        <img src="<%= shrimpo.user.avatar_url_or_default %>" alt="" />
      <% end %>
    </div>
    <div class="flex flex-col">
      <h2 class="text-xl"><%= shrimpo.title %></h2>
      <div class="text-white"><%= shrimpo.shrimpo_entries.count %> entries</div>
    </div>
  </div>
  <div>
    <div class="text-white font-bold"><%= shrimpo.translated_status %></div>
    <% if shrimpo.status == "running" %>
      <%# Web component for the countdown timer — no framework needed %>
      <shrimpo-countdown end-at="<%= shrimpo.end_at.iso8601 %>"></shrimpo-countdown>
    <% end %>
    <div class="text-white">
      <span class="font-bold">Host:</span> <%= shrimpo.username %>
    </div>
  </div>
<% end %>
